{
  "name": "todo-node",
  "version": "1.0.0",
  "type": "module",
  "description": "A To-Do app built in Node.js.",
  "main": "index.js",
  "scripts": {
    "test": "npm run build:test && node --test",
    "start": "npm run build:src && node dist/src/index.js",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.test.json",
    "build:src": "tsc -p tsconfig.json",
    "build:test": "tsc -p tsconfig.test.json"
  },
  "keywords": [
    "Node.js"
  ],
  "author": "Mateus Colombo Godoy",
  "license": "MIT",
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.14.12",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@inquirer/prompts": "^5.3.2"
  }
}